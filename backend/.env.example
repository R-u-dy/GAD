# Copy this file to .env and fill in your values.
# The app runs in MOCK_MODE (no API key needed) until you set OPENAI_API_KEY.

# --- LLM provider ---
OPENAI_API_KEY=
# Optional: use OpenRouter instead of OpenAI directly (lets you try
# Gemini, Claude, OlympicCoder, etc. the way the paper does).
# If set, OPENROUTER_API_KEY takes priority over OPENAI_API_KEY.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- External binaries (must be installed separately, see README.md) ---
OPENSCAD_BIN=openscad
SLICER_BIN=prusa-slicer
# Slicer config profile (.ini) exported from PrusaSlicer/Slic3r, optional
SLICER_CONFIG=

# --- 3D printer (optional) ---
PRINTER_PORT=
PRINTER_BAUDRATE=115200

# --- Behavior ---
# If true (or if no API key is set), the LLM client returns canned
# responses instead of calling a real API, so you can test the whole
# pipeline before you have an API key.
MOCK_MODE=true

# Gemini, via Google's official OpenAI-compatible endpoint. Get a key at
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Production hardening (leave defaults for local dev) ---
# Comma-separated allowed origins, e.g. https://gad.example.com . "*" is
# fine for local dev but should be locked down before going public.
CORS_ORIGINS=*
# Requests/minute per IP allowed to use the *server's own* API key.
# Visitors using their own key (Settings > API keys) aren't limited.
RATE_LIMIT_PER_MINUTE=10
